# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get from https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Admin auth ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-admin-password-here
SECRET_KEY=your-long-random-secret-key-here   # python -c "import secrets; print(secrets.token_hex(32))"

# ── Email OTP (Gmail SMTP) ─────────────────────────────────────────────────
# Use a Gmail App Password (not your real password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx              # 16-char App Password
ADMIN_EMAIL=your-gmail@gmail.com               # Where OTP codes are sent

# ── Firebase Storage (optional — for receipt uploads) ──────────────────────
# Without these, orders still save but receipts are not stored.
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line (no newlines)
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
